---
import { getCollection } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";

const docs = (await getCollection("docs")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<DocsLayout
  title="Documentation"
  description="Simple, current documentation for sixpack v0.0.1."
  docs={docs}
>
  <p class="docs-kicker">sixpack v0.0.1</p>
  <h1>Documentation</h1>
  <p class="docs-description">
    Start with the overview, then use the focused guides for an AI application,
    the generated Rust API, and the storage format.
  </p>

  <div class="docs-index">
    {
      docs.map((entry) => (
        <a href={`/docs/${entry.id}`}>
          <h2>{entry.data.title}</h2>
          <p>{entry.data.description}</p>
        </a>
      ))
    }
  </div>
</DocsLayout>
